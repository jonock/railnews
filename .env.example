PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_PATH=./data/railnews.sqlite

# Optional. If absent, the app still creates an extractive briefing.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Protects write APIs and cron trigger endpoint. Set this in Coolify.
ADMIN_TOKEN=change-me
CRON_SECRET=change-me-too

# Europe/Zurich is the default schedule timezone.
BRIEFING_CRON=15 6 * * *
BRIEFING_TIMEZONE=Europe/Zurich

# Region/focus gate. Articles must match one of these before topic classification.
FOCUS_KEYWORDS=Schweden,Norwegen,Dänemark,Finnland,Skandinavien,Sweden,Norway,Denmark,Finland,Scandinavia,Trafikverket,Bane NOR,Banedanmark,Väylävirasto,DSB,SJ,VR
